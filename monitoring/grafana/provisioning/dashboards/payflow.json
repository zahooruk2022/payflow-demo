{
  "uid": "payflow-main",
  "title": "PayFlow — Banking Operations",
  "tags": ["payflow", "banking", "payments"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Payments Submitted",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "payflow_payments_submitted_total", "legendFormat": "Submitted", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "short" } }
    },
    {
      "id": 2, "type": "stat", "title": "Payments Completed",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "payflow_payments_completed_total", "legendFormat": "Completed", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" }, "unit": "short" } }
    },
    {
      "id": 3, "type": "stat", "title": "Fraud Alerts",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "payflow_payments_flagged_total", "legendFormat": "Flagged", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "unit": "short" } }
    },
    {
      "id": 4, "type": "stat", "title": "Volume Settled (GBP)",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "payflow_payment_volume_gbp_total", "legendFormat": "Volume", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" }, "unit": "currencyGBP" } }
    },
    {
      "id": 5, "type": "stat", "title": "JVM Heap Used",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "Heap", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "bytes", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200000000 }, { "color": "red", "value": 400000000 }] } } }
    },
    {
      "id": 6, "type": "stat", "title": "CPU Usage",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "process_cpu_usage * 100", "legendFormat": "CPU %", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }] } } }
    },
    {
      "id": 7, "type": "timeseries", "title": "Payment Rate (per minute)",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(payflow_payments_submitted_total[1m]) * 60", "legendFormat": "Submitted/min", "refId": "A" },
        { "expr": "rate(payflow_payments_completed_total[1m]) * 60", "legendFormat": "Completed/min", "refId": "B" },
        { "expr": "rate(payflow_payments_flagged_total[1m]) * 60", "legendFormat": "Flagged/min", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Submitted/min" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#3b82f6" } }] },
          { "matcher": { "id": "byName", "options": "Completed/min" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#10b981" } }] },
          { "matcher": { "id": "byName", "options": "Flagged/min" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ef4444" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8, "type": "gauge", "title": "Fraud Rate",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "payflow_payments_flagged_total / clamp_min(payflow_payments_submitted_total, 1) * 100",
        "legendFormat": "Fraud Rate %",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true, "showThresholdMarkers": true, "minVizWidth": 75 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 25 }] } } }
    },
    {
      "id": 9, "type": "timeseries", "title": "JVM Memory",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "Heap Used", "refId": "A" },
        { "expr": "sum(jvm_memory_max_bytes{area=\"heap\"})", "legendFormat": "Heap Max", "refId": "B" },
        { "expr": "sum(jvm_memory_used_bytes{area=\"nonheap\"})", "legendFormat": "Non-Heap", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 10, "type": "timeseries", "title": "HTTP Request Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{uri=~\"/api/.*\"}[1m])) by (uri)", "legendFormat": "{{uri}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 8 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 11, "type": "timeseries", "title": "Payment Processing Time (p50 / p95 / p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(payflow_payment_processing_seconds_bucket[2m]))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(payflow_payment_processing_seconds_bucket[2m]))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, rate(payflow_payment_processing_seconds_bucket[2m]))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 8 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 12, "type": "timeseries", "title": "CPU & System Load",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "process_cpu_usage * 100", "legendFormat": "Process CPU %", "refId": "A" },
        { "expr": "system_cpu_usage * 100", "legendFormat": "System CPU %", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "lineWidth": 2, "fillOpacity": 12 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    }
  ]
}
